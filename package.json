{
  "name": "bigbookshelf-webos",
  "version": "0.13.0-beta",
  "author": "KTheMan",
  "description": "Bigbookshelf (BBS) — Audiobookshelf client for LG webOS TV",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve -l 1337 -s dist",
    "build": "npm run build:web && npm run build:webos",
    "build:web": "nuxt generate",
    "build:webos": "ares-package dist --output ipk",
    "package": "npm run build:webos",
    "serve": "npx serve -l 1337 -s dist",
    "lint": "eslint . --ext .js,.vue",
    "clean": "rm -rf dist ipk"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@nuxtjs/axios": "^5.13.6",
    "@teckel/vue-pdf": "^4.3.5",
    "buffer": "^6.0.3",
    "core-js": "^3.15.1",
    "date-fns": "^2.25.0",
    "epubjs": "0.3.88",
    "fast-average-color": "^9.3.0",
    "libarchive.js": "^1.3.0",
    "nuxt": "^2.15.7",
    "socket.io-client": "^4.1.3",
    "v-click-outside": "^3.2.0",
    "vue-toastification": "^1.7.11",
    "vuedraggable": "^2.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "postcss": "^8.4.33",
    "postcss-custom-properties": "^15.0.1",
    "serve": "^14.0.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.1"
  },
  "browserslist": [
    "Chrome >= 38"
  ],
  "webOS": {
    "minVersion": "3.0.0",
    "targetDevice": "tv"
  }
}
